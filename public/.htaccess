# Serifa Lab — configuração de servidor para hospedagem Apache/LiteSpeed
# (Hostinger). Este arquivo vive em public/, então o build o copia para a raiz
# de dist/ e ele sobe junto com o site.
#
# É o equivalente ao netlify.toml, que só funciona na Netlify. Se um dia o
# deploy voltar para lá, os dois podem coexistir — cada host lê o seu.

# ----------------------------------------------------------------- 404
# Sem isto o visitante vê a página de erro genérica da Hostinger em vez da
# 404 do site (dist/404.html).
ErrorDocument 404 /404.html

# ------------------------------------------------------- HTTPS + domínio
# O canonical, o og:url e o sitemap apontam para https://serifalabs.com (sem
# www). Estas regras evitam que o mesmo conteúdo responda em 4 endereços
# diferentes, o que divide o sinal de SEO.
#
# A hPanel da Hostinger tem um botão "Forçar HTTPS". Se você ativá-lo lá,
# remova o primeiro bloco abaixo para não ter duas camadas de redirecionamento.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http:// → https://
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # www.serifalabs.com → serifalabs.com
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ------------------------------------------------------------- CACHE
# Os arquivos em /_astro/ têm hash no nome: mudou o conteúdo, muda o nome.
# Por isso podem ser cacheados para sempre (era o primeiro [[headers]] do
# netlify.toml). O HTML NÃO pode — senão o visitante fica preso numa versão
# antiga depois de cada deploy.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|svg|png|jpg|jpeg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(html|xml|txt|json)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Cabeçalhos de segurança básicos.
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --------------------------------------------------------- COMPRESSÃO
# A Hostinger costuma comprimir por padrão; explicitar não custa e garante.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ------------------------------------------------------------- MIME
# Garante o Content-Type correto para as fontes e o webp/avif.
<IfModule mod_mime.c>
  AddType font/woff2 .woff2
  AddType image/webp .webp
  AddType image/avif .avif
</IfModule>
