---
// Botão flutuante de WhatsApp — CTA de conversão fixo no canto inferior direito.
// Fica no Base.astro, então aparece em todas as páginas (home, cases, obrigado, 404).
//
// O número vem de studio.json → social (mesma fonte do rodapé), então não há
// URL duplicada para manter em sincronia. Se o item "WhatsApp" for removido de
// lá, o botão simplesmente não renderiza. A mensagem pré-preenchida reduz a
// fricção do primeiro contato.
import studio from '../data/studio.json';

const wa = studio.social.find((s) => s.label.toLowerCase() === 'whatsapp');
const msg = 'Olá! Vim pelo site da Serifa Lab e gostaria de conversar sobre um projeto.';
const href = wa?.url
  ? `${wa.url}${wa.url.includes('?') ? '&' : '?'}text=${encodeURIComponent(msg)}`
  : null;
---
{
  href && (
    <a
      class="wa-fab"
      href={href}
      target="_blank"
      rel="noopener"
      aria-label="Conversar no WhatsApp"
    >
      <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false">
        <path
          fill="currentColor"
          d="M16.003 3.2c-7.06 0-12.8 5.74-12.8 12.8 0 2.26.6 4.46 1.73 6.4L3.2 28.8l6.57-1.72a12.74 12.74 0 0 0 6.23 1.6h.01c7.06 0 12.8-5.74 12.8-12.8s-5.75-12.68-12.81-12.68zm0 23.04h-.01a10.6 10.6 0 0 1-5.4-1.48l-.39-.23-3.9 1.02 1.04-3.8-.25-.4a10.56 10.56 0 0 1-1.62-5.65c0-5.86 4.77-10.63 10.64-10.63 2.84 0 5.51 1.11 7.52 3.12a10.56 10.56 0 0 1 3.11 7.52c0 5.87-4.77 10.64-10.63 10.64zm5.83-7.96c-.32-.16-1.89-.93-2.18-1.04-.29-.11-.5-.16-.71.16-.21.32-.82 1.04-1.01 1.25-.19.21-.37.24-.69.08-.32-.16-1.35-.5-2.57-1.59-.95-.85-1.59-1.9-1.78-2.22-.19-.32-.02-.49.14-.65.14-.14.32-.37.48-.56.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.71-1.71-.97-2.34-.26-.62-.52-.54-.71-.55-.18-.01-.4-.01-.61-.01-.21 0-.56.08-.85.4-.29.32-1.11 1.09-1.11 2.64 0 1.55 1.13 3.06 1.29 3.27.16.21 2.23 3.4 5.4 4.77.75.32 1.34.52 1.8.66.76.24 1.44.21 1.98.13.6-.09 1.89-.77 2.16-1.52.27-.75.27-1.39.19-1.52-.08-.13-.29-.21-.61-.37z"
        />
      </svg>
      <span class="wa-fab-tip" aria-hidden="true">Fale conosco</span>
    </a>
  )
}
