---
// Stats — the 4 numbers, from studio.json → stats[]. An optional `em` renders
// the accented suffix (e.g. the "%" of 100%). Confirm these numbers before launch.
import studio from '../data/studio.json';
const stats = studio.stats as Array<{ n: string; em?: string; l: string }>;
---
<section class="stats">
  <div class="wrap stats-grid">
    {
      stats.map((s) => (
        <div class="stat reveal">
          <div class="n">{s.n}{s.em && <em>{s.em}</em>}</div>
          <div class="l">{s.l}</div>
        </div>
      ))
    }
  </div>
</section>
